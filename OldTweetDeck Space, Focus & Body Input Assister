// ==UserScript==
// @name        OldTweetDeck Space, Focus & Body Input Assister
// @namespace   Violentmonkey Scripts
// @version     3.0
// @description  ハッシュタグ前のスペース補正に加え、本文入力開始時にも自動で半角スペースを適切な位置に補正する統合スクリプト
// @author       tako
// @match        https://x.com/i/tweetdeck
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    setInterval(function() {
        var form = document.querySelector('textarea.js-compose-text, textarea[data-testid="tweetTextarea"], .compose-text textarea');
        if (!form) return;

        // 1. プレースホルダーの一元管理（多重表示の防止）
        if (form.placeholder) {
            var cleanPlaceholder = form.placeholder.replace(/(TweetFormat|ReplyFormat|PostFormat)[^/]*\/\s*/g, '');
            var targetPlaceholder = 'TweetFormat / ' + cleanPlaceholder;
            if (form.placeholder !== targetPlaceholder) {
                form.placeholder = targetPlaceholder;
            }
        }

        var text = form.value;

        // 入力欄にハッシュタグが含まれているときのみ作動
        if (text.includes('#')) {

            // メンションとタグを綺麗に抽出・整理
            var currentMentions = text.match(/(?:^|\s)@[A-Za-z0-9_]+/g) || [];
            var currentTags = text.match(/#\S+/g) || [];

            var uniqueMentions = [...new Set(currentMentions.map(s => s.trim()))].join(' ');
            var cleanTags = currentTags.map(s => s.trim()).join(' ');

            // 【判定用】現在のテキストから「メンション」「半角スペース類」「タグ」を全て除外して残った文字列 ＝ ユーザーの「本文」
            // 透明文字(\u200B)も除外して純粋な本文の文字数を測ります
            var bodyText = text.replace(/(?:^|\s)@[A-Za-z0-9_]+/g, '').replace(/#\S+/g, '').replace(/[\s\u200B]/g, '');

            // --- パターンA: まだ本文が入力されていない「初期状態」 ---
            if (bodyText === '') {
                var correctInitialTemplate = '';
                if (uniqueMentions.length > 0) {
                    correctInitialTemplate = uniqueMentions + ' ' + cleanTags;
                } else {
                    correctInitialTemplate = '\u200B ' + cleanTags;
                }

                if (text !== correctInitialTemplate) {
                    updateTextAndNotify(form, correctInitialTemplate);
                    // カーソルを文頭（半角スペースの左側）に固定
                    form.selectionEnd = 0;
                    form.selectionStart = 0;
                    form.focus();
                }
            }

            // --- パターンB: 本文が入力され始めた「入力中状態」【新規追加】 ---
            else {
                // ユーザーが打ち込んだ純粋な本文（メンション・タグ以外の文字列全体）を抽出
                var rawBody = text;
                currentMentions.forEach(function(m) { rawBody = rawBody.replace(m, ''); });
                currentTags.forEach(function(t) { rawBody = rawBody.replace(t, ''); });
                rawBody = rawBody.trim(); // 前後の不要な余白をカット

                // 理想の配置: 「メンション(あれば) + 本文 + 半角スペース1つ + タグ」
                var correctInputTemplate = '';
                if (uniqueMentions.length > 0) {
                    correctInputTemplate = uniqueMentions + ' ' + rawBody + ' ' + cleanTags;
                } else {
                    correctInputTemplate = rawBody + ' ' + cleanTags;
                }

                // 現在の入力欄が理想の形（本文の後にスペースが空いている状態）になっていない場合、自動補正
                if (text !== correctInputTemplate) {
                    // 現在のカーソル位置（タイピング中の位置）を一時記憶
                    var currentCursor = form.selectionStart;

                    updateTextAndNotify(form, correctInputTemplate);

                    // カーソルがハッシュタグ側に飛んでいかないよう、入力していた「本文の末尾」にフォーカスを戻す
                    // リプライ時はメンションの文字数分だけ位置をずらす
                    var offset = uniqueMentions.length > 0 ? (uniqueMentions.length + 1) : 0;
                    var newCursorPos = offset + rawBody.length;

                    form.selectionStart = newCursorPos;
                    form.selectionEnd = newCursorPos;
                    form.focus();
                }
            }
        }
    }, 100);

    // React等の内部Stateを裏側から安全に書き換えるための共通関数
    function updateTextAndNotify(formElement, newText) {
        var nativeInputValueSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, "value").set;
        nativeInputValueSetter.call(formElement, newText);
        formElement.dispatchEvent(new Event('input', { bubbles: true }));
        formElement.dispatchEvent(new Event('change', { bubbles: true }));
    }
})();
